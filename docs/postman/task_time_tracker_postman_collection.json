{
  "info": {
    "_postman_id": "7e2f9c1a-7b6f-4fd4-9bdc-ttt-collection",
    "name": "Task Time Tracker API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Коллекция для проверки Task Time Tracker API: login, tasks, time-records. После логина токен автоматически сохраняется в collection variables. После создания задачи taskId тоже сохраняется автоматически."
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "taskId",
      "value": "1"
    },
    {
      "key": "employeeId",
      "value": "101"
    }
  ],
  "item": [
    {
      "name": "1. Auth - Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "var json = pm.response.json();",
              "if (json.token) {",
              "    pm.collectionVariables.set('token', json.token);",
              "}",
              "",
              "pm.test('Token is present', function () {",
              "    pm.expect(json.token).to.be.a('string').and.not.empty;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"nikita\",\n  \"password\": \"password\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "login"
          ]
        },
        "description": "Логин и автоматическое сохранение JWT в collection variable token."
      }
    },
    {
      "name": "2. Tasks - Create Task",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200 or 201', function () {",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
              "});",
              "",
              "var json = pm.response.json();",
              "if (json.id) {",
              "    pm.collectionVariables.set('taskId', String(json.id));",
              "}",
              "",
              "pm.test('Task id is present', function () {",
              "    pm.expect(json.id).to.exist;",
              "});",
              "",
              "pm.test('Task status is NEW', function () {",
              "    pm.expect(json.status).to.eql('NEW');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{token}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Implement REST API\",\n  \"description\": \"Create controllers and services\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/tasks",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "tasks"
          ]
        }
      }
    },
    {
      "name": "3. Tasks - Get Task By Id",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{token}}",
              "type": "string"
            }
          ]
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/tasks/{{taskId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "tasks",
            "{{taskId}}"
          ]
        }
      }
    },
    {
      "name": "4. Tasks - Update Task Status",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{token}}",
              "type": "string"
            }
          ]
        },
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"IN_PROGRESS\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/tasks/{{taskId}}/status",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "tasks",
            "{{taskId}}",
            "status"
          ]
        }
      }
    },
    {
      "name": "5. Time Records - Create",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{token}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"employeeId\": {{employeeId}},\n  \"taskId\": {{taskId}},\n  \"startTime\": \"2026-04-21T10:00:00\",\n  \"endTime\": \"2026-04-21T12:00:00\",\n  \"workDescription\": \"Implemented service layer\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/time-records",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "time-records"
          ]
        }
      }
    },
    {
      "name": "6. Time Records - Get By Employee And Period",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{token}}",
              "type": "string"
            }
          ]
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/time-records?employeeId={{employeeId}}&startTime=2026-04-21T00:00:00&endTime=2026-04-21T23:59:59",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "time-records"
          ],
          "query": [
            {
              "key": "employeeId",
              "value": "{{employeeId}}"
            },
            {
              "key": "startTime",
              "value": "2026-04-21T00:00:00"
            },
            {
              "key": "endTime",
              "value": "2026-04-21T23:59:59"
            }
          ]
        }
      }
    },
    {
