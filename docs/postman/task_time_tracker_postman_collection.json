        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"employeeId\": {{employeeId}},\n  \"taskId\": {{taskId}},\n  \"startTime\": \"2026-04-21T12:00:00\",\n  \"endTime\": \"2026-04-21T10:00:00\",\n  \"workDescription\": \"wrong time range\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/time-records",
          "host": [
